    "check": "npm test && npm run build",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20.20 <23"
  },
  "dependencies": {
    "@alicloud/ocr-api20210707": "^3.1.3",
    "@alicloud/openapi-client": "^0.4.15",
    "@ant-design/icons": "^6.3.2",
    "@vitejs/plugin-react": "latest",
    "ali-oss": "^6.23.0",
    "antd": "^6.5.0",
    "lucide-react": "latest",
    "pg": "^8.22.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "supabase": "^2.108.0"
  }
}
