{
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local scripts/dev.mjs",
    "api": "node --env-file-if-exists=.env.local server/server.mjs",
    "start": "node --env-file-if-exists=.env.production server/server.mjs",
    "migrate": "node --env-file-if-exists=.env.production --env-file-if-exists=.env.local scripts/migrate.mjs",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:stop": "supabase stop",
    "typecheck": "tsc -b",
